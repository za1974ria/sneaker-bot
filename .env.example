# Copier ce fichier : cp .env.example .env
# Puis : nano .env  — une variable par ligne, sans guillemets autour de la valeur.
# chmod 600 .env
#
# Obtenir une clé : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# Optionnel :
# CLAUDE_MODEL=claude-3-5-haiku-20241022
# DISABLE_CLAUDE_CREDIBILITY=1

